APP_NAME=Fazenda Bela Vista
SECRET_KEY=troque-esta-chave-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
PORT=8000
DATABASE_URL_OVERRIDE=
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=fazenda_cafe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
ADMIN_EMAIL=admin@fazenda.local
ADMIN_PASSWORD=admin123
OPENAI_API_KEY=
OPENAI_RECOMMENDATION_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=25
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Fazenda Bela Vista
SMTP_USE_TLS=true
TWO_FACTOR_CODE_MINUTES=10
TWO_FACTOR_MAX_ATTEMPTS=5
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Opcional: no Google Cloud habilite "Maps Static API" (prévia satélite PNG) e "Maps JavaScript API" (desenho no mapa em satélite na página Fazendas). Mesma chave.
GOOGLE_MAPS_API_KEY=
# Supabase Storage — obrigatorio para o backup funcionar.
# Copie esses valores em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Buckets que devem existir no Supabase Storage (crie-os manualmente se necessario):
SUPABASE_BUCKET_DB=backups-db
SUPABASE_BUCKET_FILES=anexos
